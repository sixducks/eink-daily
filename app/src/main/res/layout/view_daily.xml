<?xml version="1.0" encoding="utf-8"?>
<!-- 关键：诗词区与历史区各占一块“固定”空间(layout_weight)，字号用 autoSize 自动缩放去适配，
     诗词再长也只在自己区域内缩，绝不侵占历史；页脚“更新于”钉在最底部始终可见。 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:id="@+id/tvDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:letterSpacing="0.03"
        android:textColor="#000000"
        android:textSize="18sp" />

    <ImageView
        android:id="@+id/ivBing"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_marginTop="14dp"
        android:background="#EEEEEE"
        android:contentDescription="Bing"
        android:scaleType="centerCrop" />

    <TextView
        android:id="@+id/tvBingCaption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="#555555"
        android:textSize="12sp"
        android:textStyle="italic" />

    <!-- 诗词区（固定一块，字号自动缩放，居中） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.1"
        android:layout_marginTop="16dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvPoem"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:autoSizeMaxTextSize="34sp"
            android:autoSizeMinTextSize="13sp"
            android:autoSizeStepGranularity="1sp"
            android:autoSizeTextType="uniform"
            android:fontFamily="serif"
            android:gravity="center"
            android:lineSpacingMultiplier="1.25"
            android:textColor="#000000" />

        <TextView
            android:id="@+id/tvPoemMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="serif"
            android:textColor="#444444"
            android:textSize="16sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:alpha="0.25"
        android:background="#000000" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:letterSpacing="0.12"
        android:text="历史上的今天"
        android:textColor="#555555"
        android:textSize="15sp" />

    <!-- 历史区（固定一块，字号自动缩放） -->
    <TextView
        android:id="@+id/tvHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"
        android:autoSizeMaxTextSize="18sp"
        android:autoSizeMinTextSize="11sp"
        android:autoSizeStepGranularity="1sp"
        android:autoSizeTextType="uniform"
        android:lineSpacingMultiplier="1.3"
        android:textColor="#000000" />

    <TextView
        android:id="@+id/tvUpdated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="end"
        android:textColor="#666666"
        android:textSize="12sp" />

</LinearLayout>
